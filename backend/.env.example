# Django core
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Frontend origins (for CORS + CSRF)
FRONTEND_URL=http://localhost:5173
# Optional comma-separated list if you use multiple domains
# FRONTEND_URLS=http://localhost:5173,https://your-frontend.vercel.app

# Cookie/session behavior (production recommended values)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Database (local fallback when DATABASE_URL is not set)
DB_NAME=huyuhoydb
DB_USER=root
DB_PASSWORD=root
DB_HOST=localhost
DB_PORT=3306

# Render/production database URL (Postgres)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Optional email settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
