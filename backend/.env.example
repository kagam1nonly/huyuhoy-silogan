# Django core
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.onrender.com

# Database (production)
DJANGO_USE_SQLITE=False
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
# Persist uploaded meal images on Render disk mount
DJANGO_MEDIA_ROOT=/var/data/media

# Optional (recommended): persistent media via Cloudinary (free tier)
# Set this in production to avoid Render ephemeral filesystem issues
# CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# CLOUDINARY_MEDIA_FOLDER=huyuhoy/meal_images

# Frontend origins (for CORS + CSRF)
FRONTEND_URL=https://your-frontend-domain.com
# Optional comma-separated list if you use multiple domains
# FRONTEND_URLS=https://your-frontend-domain.com,https://your-secondary-domain.com

# Optional: protect /api/keepalive/ with a shared token
KEEPALIVE_TOKEN=replace-with-random-token

# Cookie/session behavior (production recommended values)
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=None
CSRF_COOKIE_SAMESITE=None
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Optional email settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
